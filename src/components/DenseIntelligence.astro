---
type Props = { locale: "en" | "zh" };
const { locale } = Astro.props;

const copy = locale === "zh" ? {
  eyebrow: "Dense intelligence · 密集智能",
  title: "Argus 可以完成“密集智能任务”：让智能连续发生，而不是零散投入。",
  body: "人类拥有很强的智能，但天然受睡眠、饮食、日常事务、娱乐和上下文切换约束。一项研究可能持续几个月或几年，真正用于推理、实验和复盘的智能投入却分散在许多短时间片里。",
  definitionLabel: "定义",
  definition: "密集智能任务，是在连续时间窗内，以高频、低空档的方式持续调用推理、工具和验证，直到形成可审计成果的任务。",
  humanTag: "MONTHS / YEARS",
  humanTitle: "人类研究：高价值，但时间稀疏",
  humanBody: "智能投入被生物节律、生活安排和频繁切换拉长。每次重新进入问题，还需要恢复上下文。",
  humanSteps: [["提出 idea", true], ["睡眠 / 日常", false], ["查资料", true], ["会议 / 切换", false], ["跑实验", true], ["等待 / 返工", false], ["形成结论", true]],
  argusTag: "48H CONTINUOUS RUN",
  argusTitle: "Argus Life：连续工作的密集智能",
  argusBody: "Argus 可以持续两天执行同一研究目标，不需要睡眠或娱乐，并在执行中读取证据、更新记忆、调整策略。",
  argusSteps: [["规划", true], ["检索", true], ["写代码", true], ["跑实验", true], ["读证据", true], ["评审", true], ["重试", true], ["沉淀", true]],
  formulaLabel: "价值转换链",
  formula: [["TOKEN", "可计量的推理与行动预算"], ["密集智能", "连续的决策—执行—验证循环"], ["研究产物", "实验、证明、代码、数据与论文"], ["研究价值", "更快抵达可审计、可复用的结果"]],
  foot: "Token 不是最终产品。Argus 把 Token 转化为连续投入的密集智能，再转化为真实研究价值。",
} : {
  eyebrow: "Dense intelligence",
  title: "Argus executes dense-intelligence tasks: intelligence applied continuously, not intermittently.",
  body: "Human intelligence is powerful, but naturally constrained by sleep, meals, daily life, leisure, and context switching. A research effort may span months or years while the actual reasoning, experimentation, and review arrive in scattered time slices.",
  definitionLabel: "Definition",
  definition: "A dense-intelligence task sustains high-frequency reasoning, tool use, verification, and iteration across a continuous time window until it produces an auditable result.",
  humanTag: "MONTHS / YEARS",
  humanTitle: "Human research: high value, sparse in time",
  humanBody: "Biological rhythms, daily obligations, and context switching spread the intelligence across time. Each return to the problem also requires context recovery.",
  humanSteps: [["Form idea", true], ["Sleep / life", false], ["Read", true], ["Meet / switch", false], ["Experiment", true], ["Wait / retry", false], ["Conclude", true]],
  argusTag: "48H CONTINUOUS RUN",
  argusTitle: "Argus Life: continuous dense intelligence",
  argusBody: "Argus can pursue one research objective for two continuous days without sleep or leisure, reading evidence, updating memory, and changing strategy as it works.",
  argusSteps: [["Plan", true], ["Retrieve", true], ["Build", true], ["Experiment", true], ["Read evidence", true], ["Review", true], ["Retry", true], ["Distill", true]],
  formulaLabel: "Value conversion chain",
  formula: [["TOKEN", "Measurable reasoning and action budget"], ["Dense intelligence", "Continuous decision—execution—verification loops"], ["Research artifacts", "Experiments, proofs, code, data, and papers"], ["Research value", "Faster arrival at auditable, reusable results"]],
  foot: "Tokens are not the final product. Argus converts tokens into continuously applied dense intelligence, then into real research value.",
};
---

<section id="dense-intelligence" class="section surface dense-intelligence">
  <div class="shell">
    <div class="section-head wide">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2>{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="density-definition">
      <span>{copy.definitionLabel}</span>
      <strong>{copy.definition}</strong>
    </div>

    <div class="density-comparison">
      <article class="card density-track density-track--human">
        <div class="density-track__head">
          <span>{copy.humanTag}</span>
          <h3>{copy.humanTitle}</h3>
          <p>{copy.humanBody}</p>
        </div>
        <div class="density-timeline" aria-hidden="true">
          {copy.humanSteps.map(([label, active]) => <div class:list={["density-event", { gap: !active }]}><i></i><span>{label}</span></div>)}
        </div>
      </article>

      <article class="card density-track density-track--argus">
        <div class="density-track__head">
          <span>{copy.argusTag}</span>
          <h3>{copy.argusTitle}</h3>
          <p>{copy.argusBody}</p>
        </div>
        <div class="density-timeline" aria-hidden="true">
          {copy.argusSteps.map(([label]) => <div class="density-event"><i></i><span>{label}</span></div>)}
        </div>
      </article>
    </div>

    <div class="density-formula" aria-label={copy.formulaLabel}>
      {copy.formula.map(([title, body], index) => (
        <>
          <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{title}</strong><small>{body}</small></div>
          {index < copy.formula.length - 1 && <b aria-hidden="true">→</b>}
        </>
      ))}
    </div>
    <p class="density-foot">{copy.foot}</p>
  </div>
</section>

<style>
  .dense-intelligence {
    overflow: hidden;
  }

  .density-definition {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 18px;
    align-items: center;
    margin-bottom: 16px;
    padding: 18px 21px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: linear-gradient(110deg, var(--blue-soft), var(--surface), var(--gold-soft));
  }

  .density-definition span {
    color: var(--gold-dark);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .density-definition strong {
    color: var(--ink);
    font-size: 14px;
    line-height: 1.55;
  }

  .density-comparison {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .density-track {
    min-width: 0;
    padding: 24px;
  }

  .density-track--argus {
    border-color: color-mix(in srgb, var(--blue) 58%, var(--line));
    background: linear-gradient(145deg, var(--surface), color-mix(in srgb, var(--blue-soft) 46%, var(--surface)));
  }

  .density-track__head > span {
    color: var(--gold-dark);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .density-track--argus .density-track__head > span {
    color: var(--blue);
  }

  .density-track h3 {
    margin: 12px 0 7px;
    font-family: var(--serif);
    font-size: 21px;
    font-weight: 500;
  }

  .density-track p {
    min-height: 63px;
    margin: 0;
    color: var(--muted);
    font-size: 11px;
  }

  .density-timeline {
    display: flex;
    margin-top: 22px;
    overflow-x: auto;
    padding: 3px 1px 7px;
    scrollbar-width: none;
  }

  .density-timeline::-webkit-scrollbar {
    display: none;
  }

  .density-event {
    position: relative;
    min-width: 58px;
    flex: 1 0 58px;
    text-align: center;
  }

  .density-event:not(:last-child)::after {
    content: "";
    position: absolute;
    left: calc(50% + 6px);
    right: calc(-50% + 6px);
    top: 5px;
    height: 2px;
    background: var(--blue);
    opacity: 0.56;
  }

  .density-track--human .density-event:not(:last-child)::after {
    background: var(--line);
  }

  .density-event i {
    position: relative;
    z-index: 1;
    width: 12px;
    height: 12px;
    display: block;
    margin: 0 auto 9px;
    border: 2px solid var(--surface);
    border-radius: 50%;
    background: var(--blue);
    box-shadow: 0 0 0 1px var(--blue);
  }

  .density-event.gap i {
    background: var(--surface);
    box-shadow: 0 0 0 1px var(--gray, var(--line));
  }

  .density-event span {
    display: block;
    color: var(--ink-2);
    font-size: 8px;
    line-height: 1.35;
  }

  .density-event.gap span {
    color: var(--faint);
  }

  .density-formula {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 9px;
    align-items: stretch;
    margin-top: 16px;
    padding: 17px;
    border: 1px solid var(--line);
    border-radius: 15px;
    background: var(--surface-raised);
    box-shadow: var(--shadow);
  }

  .density-formula > div {
    min-width: 0;
    padding: 13px 14px;
    border-radius: 10px;
    background: var(--blue-soft);
  }

  .density-formula > div:last-of-type {
    background: var(--gold-soft);
  }

  .density-formula span,
  .density-formula strong,
  .density-formula small {
    display: block;
  }

  .density-formula span {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 8px;
  }

  .density-formula strong {
    margin-top: 7px;
    color: var(--ink);
    font-size: 13px;
  }

  .density-formula small {
    margin-top: 4px;
    color: var(--muted);
    font-size: 8.5px;
    line-height: 1.45;
  }

  .density-formula b {
    align-self: center;
    color: var(--gold-dark);
    font-family: var(--mono);
    font-size: 13px;
  }

  .density-foot {
    margin: 13px 0 0;
    color: var(--ink-2);
    font-size: 11px;
    font-weight: 700;
    text-align: center;
  }

  @media (max-width: 820px) {
    .density-definition,
    .density-comparison {
      grid-template-columns: 1fr;
    }

    .density-definition {
      gap: 7px;
    }

    .density-track p {
      min-height: 0;
    }

    .density-formula {
      grid-template-columns: 1fr;
    }

    .density-formula b {
      justify-self: center;
      transform: rotate(90deg);
    }
  }
</style>
