---
import { localeFromPath, pathForLocale } from "../i18n";
import ArgusLogo from "./ArgusLogo.astro";

const locale = localeFromPath(Astro.url.pathname);
const copy = locale === "zh" ? {
  home: "Argus 首页",
  tagline: "灯熄了，研究继续。",
  nav: "页脚导航",
  links: ["成绩", "研究", "原理", "场景", "开始使用"],
} : {
  home: "Argus home",
  tagline: "The lights go out. The research keeps moving.",
  nav: "Footer navigation",
  links: ["Results", "Research", "How it works", "Use cases", "Get started"],
};
const localized = (href: string) => pathForLocale(href, locale);
---

<footer class="site-footer">
  <div>
    <a class="footer-brand" href={localized("/")} aria-label={copy.home}>
      <ArgusLogo variant="horizontal" class="argus-logo--footer" decorative />
    </a>
    <p>{copy.tagline}</p>
  </div>
  <nav aria-label={copy.nav}>
    <a href={localized("/results.html")}>{copy.links[0]}</a>
    <a href={localized("/research.html")}>{copy.links[1]}</a>
    <a href={localized("/how.html")}>{copy.links[2]}</a>
    <a href={localized("/use-cases.html")}>{copy.links[3]}</a>
    <a href={localized("/start.html")}>{copy.links[4]}</a>
  </nav>
</footer>
