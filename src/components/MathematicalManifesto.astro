---
type Props = { locale: "en" | "zh" };
const { locale } = Astro.props;

const copy = locale === "zh" ? {
  eyebrow: "A mathematical formalization",
  title: "把 Argus 的理念写成一组可解释的数学对象。",
  body: "这些公式不是装饰。它们分别描述：单位时间内的有效智能密度、Life 如何在不更新模型参数的情况下演进、能力如何通过 evidence gate 扩展，以及 Token 最终如何转化为研究价值。",
  cards: [
    ["01", "密集智能密度", "单位墙钟时间内，被真正转化为有效推理、行动和验证的 Token 密度。关键不是 Token 总量，而是连续性与转化效率。"],
    ["02", "Life / Harness 在线演进", "执行轨迹与证据更新 Memory、Skills、Tools、Verifiers 和 Routing；在线阶段不要求改变底层模型参数。"],
    ["03", "OOD 能力集合扩张", "只有通过证据门槛的新能力才进入能力集合，因此系统可以在保留已有能力的同时增加宽度与深度。"],
    ["04", "研究价值积分", "研究价值由智能密度、信息增益、结论有效性和成果复用率共同决定，而不是由消耗 Token 的数量单独决定。"],
    ["05", "过程数据的信息优势", "论文只保留最终结果；过程数据还包含状态、动作、证据、反馈和 Harness 更新，因而拥有更完整的决策信息。"],
  ],
  comparison: "这里比较的是连续时间内的智能投入密度，而不是宣称单步智能质量必然更高。",
} : {
  eyebrow: "A mathematical formalization",
  title: "Expressing the Argus thesis as interpretable mathematical objects.",
  body: "These equations are not decoration. They formalize useful intelligence per unit time, Life evolution without parameter updates, evidence-gated OOD expansion, and the conversion of tokens into research value.",
  cards: [
    ["01", "Dense-intelligence density", "Useful tokens converted into reasoning, action, and verification per unit of wall-clock time. The key variables are continuity and conversion efficiency—not token volume alone."],
    ["02", "Online Life / Harness evolution", "Trajectories and evidence update memory, skills, tools, verifiers, and routing while the underlying model parameters need not change online."],
    ["03", "OOD capability-set expansion", "Only evidence-gated capabilities enter the set, allowing breadth and depth to increase while validated existing capabilities remain available."],
    ["04", "Research-value integral", "Research value depends jointly on intelligence density, information gain, validity, and reusability—not simply on the number of tokens consumed."],
    ["05", "The information advantage of process data", "A paper retains the final result. Process data also retains states, actions, evidence, feedback, and harness updates—the decision path behind the result."],
  ],
  comparison: "This compares the density of intelligent work across continuous time, not an unconditional claim that every individual step has higher intelligence quality.",
};
---

<section class="section tight math-manifesto" aria-labelledby="math-manifesto-title">
  <div class="shell">
    <div class="section-head wide">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2 id="math-manifesto-title">{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="math-grid">
      <article class="card math-card">
        <div class="math-card__meta"><span>{copy.cards[0][0]}</span><strong>{copy.cards[0][1]}</strong></div>
        <div class="equation" role="math" aria-label="Dense intelligence density">
          <span>&rho;<sub>I</sub>(T)</span>
          <b>=</b>
          <span class="fraction"><i>1</i><i>T</i></span>
          <span>&int;<sub>0</sub><sup>T</sup></span>
          <span>N&#775;<sub>tok</sub>(t)</span>
          <span>&eta;<sub>r</sub>(t)</span>
          <span>&eta;<sub>a</sub>(t)</span>
          <span>&eta;<sub>v</sub>(t)</span>
          <span>dt</span>
        </div>
        <div class="equation equation--secondary" role="math" aria-label="Argus intelligence density greater than human density over 48 hours">
          &rho;<sub>I</sub><sup>Argus</sup>(48h) &gg; &rho;<sub>I</sub><sup>human</sup>(48h)
        </div>
        <p>{copy.cards[0][2]}</p>
        <small class="math-caveat">{copy.comparison}</small>
      </article>

      <article class="card math-card">
        <div class="math-card__meta"><span>{copy.cards[1][0]}</span><strong>{copy.cards[1][1]}</strong></div>
        <div class="equation equation--stack" role="math" aria-label="Harness state update with fixed model parameters">
          <span>H<sub>t+1</sub> = U(H<sub>t</sub>, &tau;<sub>t</sub>, E<sub>t</sub>)</span>
          <span>&theta;<sub>t+1</sub> = &theta;<sub>t</sub></span>
        </div>
        <div class="equation equation--secondary equation--small" role="math">
          H<sub>t</sub> = &#123; Memory, Skills, Tools, Verifiers, Routing &#125;
        </div>
        <p>{copy.cards[1][2]}</p>
      </article>

      <article class="card math-card">
        <div class="math-card__meta"><span>{copy.cards[2][0]}</span><strong>{copy.cards[2][1]}</strong></div>
        <div class="equation equation--stack" role="math" aria-label="Evidence gated capability expansion">
          <span>C<sub>t+1</sub> = C<sub>t</sub> &cup; &#123; c : Verify(c, E<sub>t</sub>) &ge; &epsilon; &#125;</span>
          <span>W<sub>t+1</sub> &ge; W<sub>t</sub>, &nbsp; D<sub>t+1</sub>(d) &ge; D<sub>t</sub>(d)</span>
        </div>
        <p>{copy.cards[2][2]}</p>
      </article>

      <article class="card math-card">
        <div class="math-card__meta"><span>{copy.cards[3][0]}</span><strong>{copy.cards[3][1]}</strong></div>
        <div class="equation" role="math" aria-label="Research value integral">
          <span>V<sub>R</sub>(T)</span>
          <b>=</b>
          <span>&int;<sub>0</sub><sup>T</sup></span>
          <span>&rho;<sub>I</sub>(t)</span>
          <span>&Delta;I(t)</span>
          <span>p<sub>valid</sub>(t)</span>
          <span>&eta;<sub>reuse</sub>(t)</span>
          <span>dt</span>
        </div>
        <p>{copy.cards[3][2]}</p>
      </article>

      <article class="card math-card math-card--wide">
        <div class="math-card__meta"><span>{copy.cards[4][0]}</span><strong>{copy.cards[4][1]}</strong></div>
        <div class="equation equation--process" role="math" aria-label="Process data strictly contains the final artifact">
          <span>D<sub>process</sub> = &#123; (s<sub>k</sub>, a<sub>k</sub>, e<sub>k</sub>, r<sub>k</sub>, &Delta;H<sub>k</sub>) &#125;<sub>k=1</sub><sup>N</sup></span>
          <b>&supsetneq;</b>
          <span>D<sub>final</sub> = &#123; y<sup>*</sup> &#125;</span>
        </div>
        <p>{copy.cards[4][2]}</p>
      </article>
    </div>
  </div>
</section>

<style>
  .math-manifesto {
    overflow: hidden;
  }

  .math-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .math-card {
    min-width: 0;
    padding: 24px;
  }

  .math-card--wide {
    grid-column: 1 / -1;
  }

  .math-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .math-card__meta span {
    color: var(--gold-dark);
    font-family: var(--mono);
    font-size: 9px;
  }

  .math-card__meta strong {
    color: var(--ink);
    font-size: 14px;
  }

  .equation {
    min-width: 0;
    display: flex;
    gap: 8px;
    align-items: center;
    margin: 20px 0 15px;
    padding: 18px;
    overflow-x: auto;
    border: 1px solid color-mix(in srgb, var(--blue) 32%, var(--line));
    border-radius: 12px;
    background: linear-gradient(145deg, var(--blue-soft), var(--surface));
    color: var(--ink);
    font-family: "STIX Two Math", "Cambria Math", Georgia, serif;
    font-size: clamp(15px, 2vw, 21px);
    white-space: nowrap;
    scrollbar-width: none;
  }

  .equation::-webkit-scrollbar {
    display: none;
  }

  .equation b {
    color: var(--gold-dark);
    font-weight: 500;
  }

  .equation sub,
  .equation sup {
    font-size: 0.58em;
  }

  .fraction {
    display: inline-grid;
    grid-template-rows: repeat(2, auto);
    align-items: center;
    text-align: center;
    line-height: 1;
  }

  .fraction i {
    padding: 1px 5px;
    font-style: normal;
  }

  .fraction i:first-child {
    border-bottom: 1px solid currentColor;
  }

  .equation--secondary {
    margin-top: -6px;
    padding: 10px 14px;
    border-color: var(--line);
    background: var(--surface-soft);
    color: var(--ink-2);
    font-size: 15px;
  }

  .equation--small {
    font-size: 12px;
  }

  .equation--stack {
    display: grid;
    gap: 9px;
  }

  .equation--process {
    justify-content: center;
  }

  .math-card > p {
    margin: 0;
    color: var(--muted);
    font-size: 11px;
  }

  .math-caveat {
    display: block;
    margin-top: 8px;
    color: var(--faint);
    font-size: 8.5px;
  }

  @media (max-width: 820px) {
    .math-grid {
      grid-template-columns: 1fr;
    }

    .math-card--wide {
      grid-column: auto;
    }

    .math-card {
      padding: 20px;
    }

    .equation--process {
      justify-content: flex-start;
      flex-wrap: wrap;
      white-space: normal;
      font-size: 12px;
      line-height: 1.7;
    }
  }
</style>
