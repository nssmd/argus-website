---
type Props = { locale: "en" | "zh" };
import ArgusLogo from "./ArgusLogo.astro";
const { locale } = Astro.props;
const caption = locale === "zh"
  ? "Life 让目标在四个角色间持续流动，并把每次工作沉淀为下一轮的能力。"
  : "Life keeps the objective moving through four roles and turns every run into capability for the next.";
const telemetryTop = locale === "zh" ? "LIFE · 7×24" : "LIFE · 24/7";
const telemetryBottom = locale === "zh" ? "工作 → 学习" : "WORK → LEARNING";
const coreLabel = locale === "zh" ? "边工作边学习" : "learns while working";
---

<figure class="research-field" data-research-field>
  <div class="research-field__plane" data-research-field-plane>
    <span class="research-field__telemetry top-left">{telemetryTop}</span>
    <span class="research-field__telemetry bottom-right">{telemetryBottom}</span>
    <span class="research-field__corner top-left" aria-hidden="true"></span>
    <span class="research-field__corner top-right" aria-hidden="true"></span>
    <span class="research-field__corner bottom-left" aria-hidden="true"></span>
    <span class="research-field__corner bottom-right" aria-hidden="true"></span>
    {[
      [14, 32, 4], [23, 74, 3], [34, 18, 5], [42, 84, 3],
      [57, 12, 3], [63, 73, 5], [76, 25, 4], [86, 62, 3],
    ].map(([x, y, size], index) => (
      <span
        class="research-field__particle"
        data-research-field-particle
        style={`--particle-x:${x}%;--particle-y:${y}%;--particle-size:${size}px;--particle-index:${index}`}
        aria-hidden="true"
      ></span>
    ))}
    <svg class="research-field__links" viewBox="0 0 520 360" aria-hidden="true">
      <defs>
        <linearGradient id="field-blue-gold" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="var(--blue)" />
          <stop offset="0.5" stop-color="var(--gold)" />
          <stop offset="1" stop-color="var(--blue)" />
        </linearGradient>
      </defs>
      <path class="research-field__link" d="M260 180C196 112 144 88 82 86" />
      <path class="research-field__link" d="M260 180C324 112 376 88 438 86" />
      <path class="research-field__link" d="M260 180C196 248 144 272 82 274" />
      <path class="research-field__link" d="M260 180C324 248 376 272 438 274" />
      <circle cx="260" cy="180" r="112" class="research-field__orbit" />
      <circle cx="260" cy="180" r="72" class="research-field__orbit secondary" />
    </svg>
    <div class="research-field__scan" data-research-field-scan></div>
    <div class="research-field__core" data-research-field-core>
      <ArgusLogo variant="mark" class="argus-logo--research" decorative />
      <strong>ARGUS</strong>
      <span>{coreLabel}</span>
    </div>
    {[
      ["M", "Manager", "north-west"],
      ["P", "Planner", "north-east"],
      ["E", "Engineer", "south-west"],
      ["R", "Reviewer", "south-east"],
    ].map(([letter, role, position], index) => (
      <div class={`research-field__node ${position}`} data-research-field-node style={`--node-index:${index}`}>
        <i>{letter}</i>
        <span>{role}</span>
      </div>
    ))}
  </div>
  <figcaption>{caption}</figcaption>
</figure>
