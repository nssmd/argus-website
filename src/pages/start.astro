---
import ResearchVideoDemo from "../components/ResearchVideoDemo.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { localeFromPath, pathForLocale } from "../i18n";

const locale = localeFromPath(Astro.url.pathname);
const publicResearchHref = pathForLocale("/research.html", locale);
const copy = locale === "zh" ? {
  title: "Get Started · Argus",
  description: "观看 Argus 从研究方向、创作要求或数学问题出发，经真实执行、Reviewer 多轮打回到论文、文学成稿与计算验收的完整轨迹。",
  heroLead: "打开 Argus，",
  heroEm: "直接说你要什么。",
  lede: "下面不是界面截图，而是四条真实运行。两条长程研究按关键节点分段快进，保留任务输入、真实实验、Reviewer 打回、失败恢复和最终论文；文学创作与计算数学分别完整保留 1 分 29 秒和 1 分 17 秒回放。",
  fullCli: "看四条真实运行 →",
  web: "看 Web 研究轨迹 ↓",
  source: "真实录制 · 长程研究 19:54 / 11:29 → 2:17 / 2:07 · 文学 1:29 · 数学 1:17",
  flowLabel: "Argus 运行流程",
  flow: ["用户目标", "Manager 路由", "Planner 拆解", "Engineer 执行", "Reviewer 裁决", "成果交付"],
  cliTitle: "从研究方向、创作要求或数学问题，到可审查的交付物。",
  cliBody: "第一条从 8B 开源模型的自信幻觉问题出发，自主提出方法并推进到论文；第二条实现 Agreement-Margin Abstention，在真实 benchmark 上经历多轮运行、打回和恢复；第三条完成《雨停之前》的文学创作与章节审校；第四条对 Erdős–Straus 猜想执行两种精确算法，审计 848,804 条解并通过 Reviewer 验收。",
  launch: "启动",
  cliLaunchLabel: "CLI 启动命令",
  webLaunchLabel: "WebUI 启动命令",
  cliCaptionTitle: "四条真实运行，按内容选择节奏。",
  cliCaption: "两条长程研究分段压缩，保留实验、审稿、失败恢复与论文交付；文学和数学任务完整呈现章节推进、双算法执行、Reviewer 打回与最终验收。",
  cliPointsLabel: "CLI 功能",
  cliPoints: ["保留任务原文", "真实 benchmark", "文学创作与章节审校", "计算数学双算法审计", "Reviewer 打回 → 最终交付"],
  webTitle: "在 WebUI 中逐层查看角色状态、证据和交付物。",
  webBody: "直接阅读 Manager 的监控回答，再展开 Planner 计划、Engineer 命令流与 Reviewer 裁决；Mission 视图保留阶段推进、完整 replay 和审定成果。",
  videoLabel: "Argus WebUI 真实操作演示",
  videoDownload: "下载 WebUI 演示视频",
  webCaptionTitle: "26 秒 WebUI 回放",
  webCaption: "展示监控问答、角色日志、六阶段 Mission replay，以及 Reviewer 审定稿在右侧工作台和大图预览中的交付。",
  webPointsLabel: "WebUI 功能",
  webPoints: ["会话搜索", "Agent 对话", "Engineer 原始输出", "Reviewer 裁决", "Mission replay", "证据与结果预览"],
  choose: "从一句话，到一条可审查的研究轨迹。",
  chooseBody: "终端与浏览器共享同一份对话、角色状态、执行证据与 Reviewer 裁决。没有 Python 交互层，也没有隐藏在演示之外的另一套流程。",
  terminal: "Terminal",
  browser: "Browser",
  install: "浏览公开研究 →",
} : {
  title: "Get Started · Argus",
  description: "Watch Argus move from a research direction, creative brief, or mathematics problem through execution, Reviewer rejection, and verified delivery.",
  heroLead: "Open Argus. ",
  heroEm: "Tell it what you need.",
  lede: "These are not static screenshots. They are four real runs: two long-horizon research sessions condensed stage by stage, plus complete 1:29 literary-writing and 1:17 computational-mathematics replays. The request, execution, Reviewer rejection, recovery, and delivery remain visible.",
  fullCli: "Watch all four runs →",
  web: "Watch the Web research trail ↓",
  source: "Real recordings · long-horizon 19:54 / 11:29 → 2:17 / 2:07 · literature 1:29 · math 1:17",
  flowLabel: "The Argus workflow",
  flow: ["Your objective", "Manager routing", "Planner decomposition", "Engineer execution", "Reviewer decision", "Deliverable"],
  cliTitle: "From a research direction, creative brief, or math problem to an auditable deliverable.",
  cliBody: "The first run develops a method for confident hallucination in 8B open-domain QA and advances it to a paper. The second implements Agreement-Margin Abstention on real benchmarks through rejection and recovery. The third writes Before the Rain Stops through chapter review. The fourth studies Erdős–Straus with two exact algorithms, audits 848,804 solutions, and clears independent review.",
  launch: "Launch",
  cliLaunchLabel: "CLI launch command",
  webLaunchLabel: "WebUI launch command",
  cliCaptionTitle: "Four real runs, paced for their content.",
  cliCaption: "The long-horizon runs are condensed while preserving experiments, review, recovery, and paper delivery. The literature and mathematics runs fully preserve chapter progression, dual-algorithm execution, Reviewer rejection, and final acceptance.",
  cliPointsLabel: "CLI capabilities",
  cliPoints: ["Original request preserved", "Real benchmarks", "Literary writing and chapter review", "Two-algorithm math audit", "Reviewer rejection → delivery"],
  webTitle: "Inspect role state, evidence, and deliverables layer by layer in the WebUI.",
  webBody: "Read the Manager’s monitoring response, then open the Planner’s plan, the Engineer’s command stream, and the Reviewer’s verdict. Mission view preserves stage progression, complete replay, and the approved deliverable.",
  videoLabel: "A real Argus WebUI walkthrough",
  videoDownload: "Download the WebUI demo",
  webCaptionTitle: "A 26-second WebUI replay",
  webCaption: "Monitoring dialogue, role logs, a six-stage Mission replay, and the Reviewer-approved result delivered in the right-hand workspace and expanded preview.",
  webPointsLabel: "WebUI capabilities",
  webPoints: ["Session search", "Agent dialogue", "Raw Engineer output", "Reviewer verdicts", "Mission replay", "Evidence and result preview"],
  choose: "From one sentence to an auditable research trail.",
  chooseBody: "Terminal and browser share the same conversation, role state, execution evidence, and Reviewer decisions. There is no hidden Python interaction layer and no second workflow behind the demo.",
  terminal: "Terminal",
  browser: "Browser",
  install: "Browse the public research →",
};
---

<SiteLayout
  title={copy.title}
  description={copy.description}
>
  <section class="page-hero compact product-hero">
    <div class="shell demo-shell">
      <p class="eyebrow">Get started</p>
      <h1>{copy.heroLead}<em>{copy.heroEm}</em></h1>
      <p class="lede">{copy.lede}</p>
      <div class="hero-actions">
        <a class="button primary" href="#run-picker">{copy.fullCli}</a>
        <a class="button" href="#webui">{copy.web}</a>
      </div>
      <p class="demo-source">{copy.source}</p>
    </div>
  </section>

  <section class="runtime-flow" aria-label={copy.flowLabel}>
    <div class="shell demo-shell">
      <div class="runtime-flow__track">
        {copy.flow.map((label, index) => <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{label}</strong></div>)}
      </div>
    </div>
  </section>

  <section id="cli" class="section demo-section">
    <div class="shell demo-shell">
      <div class="demo-intro">
        <div class="section-head">
          <p class="eyebrow">01 · Terminal cockpit</p>
          <h2>{copy.cliTitle}</h2>
          <p>{copy.cliBody}</p>
        </div>
        <div class="launch-command" aria-label={copy.cliLaunchLabel}>
          <span>{copy.launch}</span>
          <code>argus</code>
        </div>
      </div>

      <ResearchVideoDemo />

      <p class="demo-caption">
        <strong>{copy.cliCaptionTitle}</strong>
        {copy.cliCaption}
      </p>
      <div class="demo-points" role="list" aria-label={copy.cliPointsLabel}>
        {copy.cliPoints.map((point) => <span role="listitem">{point}</span>)}
      </div>
    </div>
  </section>

  <section id="webui" class="section surface demo-section">
    <div class="shell demo-shell">
      <div class="demo-intro">
        <div class="section-head">
          <p class="eyebrow">02 · Web cockpit</p>
          <h2>{copy.webTitle}</h2>
          <p>{copy.webBody}</p>
        </div>
        <div class="launch-command" aria-label={copy.webLaunchLabel}>
          <span>{copy.launch}</span>
          <code>argus --web</code>
        </div>
      </div>

      <div class="demo-frame browser-demo">
        <div class="demo-frame__bar">
          <span class="window-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <strong>Argus WebUI</strong>
          <span>BOXIU MAIN · 699DC2C</span>
        </div>
        <video
          data-web-demo
          controls
          loop
          muted
          playsinline
          preload="none"
          poster="/assets/demos/argus-web-boxiu-86b683ba-poster.webp"
          aria-label={copy.videoLabel}
        >
          <source src="/assets/demos/argus-web-boxiu-86b683ba.webm" type="video/webm" />
          <a href="/assets/demos/argus-web-boxiu-86b683ba.webm">{copy.videoDownload}</a>
        </video>
      </div>

      <p class="demo-caption">
        <strong>{copy.webCaptionTitle}</strong>
        {copy.webCaption}
      </p>
      <div class="demo-points" role="list" aria-label={copy.webPointsLabel}>
        {copy.webPoints.map((point) => <span role="listitem">{point}</span>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell demo-shell">
      <div class="cta-band product-cta">
        <p class="eyebrow">Choose your cockpit</p>
        <h2>{copy.choose}</h2>
        <p>{copy.chooseBody}</p>
        <div class="launch-options">
          <div><span>{copy.terminal}</span><code>argus</code></div>
          <div><span>{copy.browser}</span><code>argus --web</code></div>
        </div>
        <div class="hero-actions">
          <a class="button primary" href={publicResearchHref}>{copy.install}</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<script>
  const video = document.querySelector("[data-web-demo]");

  if (
    video instanceof HTMLVideoElement &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    new IntersectionObserver(
      ([entry]) => {
        if (entry?.isIntersecting) void video.play();
        else video.pause();
      },
      { threshold: 0.25 },
    ).observe(video);
  }
</script>
