  swipeHint: "Swipe to explore",
  nowPlaying: "NOW PLAYING",
  play: "Play",
  frameTitle: "Argus CLI",
  frameBadge: "REAL RUN",
  download: "Download the current demo video",
  runs: [
    {
      category: "Research → paper",
      title: "Research direction → paper",
      duration: "19:54 → 2:17",
      pacing: "variable speed",
      label: "A real Argus run from research direction to paper delivery",
      src: "/assets/demos/argus-research-to-paper-condensed.mp4",
      poster: "/assets/demos/argus-research-to-paper-poster.webp",
    },
    {
      category: "Method → benchmark",
      title: "Method → benchmark",
      duration: "11:29 → 2:07",
      pacing: "variable speed",
