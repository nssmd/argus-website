---
type Props = { locale: "en" | "zh" };
const { locale } = Astro.props;
const FONT_SEQUENCE = [0, 8, 3, 1, 6, 2, 9, 5, 4, 7] as const;
const words = Array.from({ length: 38 }, (_, index) => ({
  text: ["ARGUS", "Argus", "argus"][index % 3],
  x: (index * 37 + 7) % 96,
  y: (index * 53 + 11) % 94,
  size: 15 + ((index * 17) % 58),
  rotate: -18 + ((index * 13) % 37),
  font: FONT_SEQUENCE[index % FONT_SEQUENCE.length],
  tone: index % 4,
  depth: 0.35 + (index % 5) * 0.14,
}));
const scrollLabel = locale === "zh" ? "进入 Argus" : "Enter Argus";
const eyebrow = locale === "zh" ? "由 Life 驱动的科研运行时" : "Life-powered research runtime";
const signature = locale === "zh" ? "7×24 工作，也从每次工作中学习" : "works 24/7 and learns from every run";
---

<section class="brand-universe" data-brand-universe aria-labelledby="brand-universe-title">
  <div class="brand-universe__words" data-brand-word-layer aria-hidden="true">
    {words.map((word, index) => (
      <span
        class={`brand-universe__word font-${word.font} tone-${word.tone}`}
        data-brand-word
        style={`--word-x:${word.x}%;--word-y:${word.y}%;--word-size:${word.size}px;--word-rotate:${word.rotate}deg;--word-depth:${word.depth};--word-index:${index}`}
      >
        {word.text}
      </span>
    ))}
  </div>
  <div class="brand-universe__halo" aria-hidden="true"></div>
  <div class="brand-universe__core-scroll" data-brand-core-scroll>
    <div class="brand-universe__core">
      <p>{eyebrow}</p>
      <h1 id="brand-universe-title" data-brand-core data-palette="0" class="font-0">ARGUS</h1>
      <span data-brand-signature>{signature}</span>
    </div>
  </div>
  <a class="brand-universe__enter" href="#intro">
    <span>{scrollLabel}</span>
    <i aria-hidden="true">↓</i>
  </a>
</section>
