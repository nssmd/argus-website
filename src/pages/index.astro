---
import SiteLayout from "../layouts/SiteLayout.astro";
import ResearchField from "../components/ResearchField.astro";
import BrandUniverse from "../components/BrandUniverse.astro";
import { localeFromPath, pathForLocale } from "../i18n";

const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => pathForLocale(path, locale);
const copy = locale === "zh" ? {
  title: "Argus — 自进化科研基础 Agent",
  description: "Argus 将每一次研究过程转化为数据、Skill 与评测信号，在真实实验中持续扩展到新的 OOD 任务，并沉淀论文背后的高价值过程数据。",
  heroEyebrow: "自进化科研运行时",
  heroLead: "给它一个研究目标。",
  heroEm: "它会边工作，边学习。",
  lede: "Argus 的 Life 7×24 持续运行：读资料、写代码、跑实验、检查证据，也从每一次成功、失败与改道中学习。经验会沉淀为 Memory、Skill、评测和过程数据，让系统不断进化，并扩展到从未见过的 OOD 任务。",
  results: "看它做出了什么 →",
  evolutionLink: "看自进化飞轮 ↓",
  conceptLabel: "Argus 核心能力",
  heroConcepts: [["Life 学习", "7×24 工作，也从工作中学习"], ["OOD 扩展", "陌生任务触发新 Skill 与新工具"], ["上限不锁死", "横向跨域，纵向持续深入"]],
  metricLabel: "核心成绩",
  metrics: [["#6", "NVIDIA 全球排名"], ["2× #1", "B200 kernel"], ["H100 + B200", "超过 human SOTA"], ["79.77s", "8×H100 speedrun"], ["41", "研究 PDF"]],
  signal: "LIFE → MISSION → 证据 → MEMORY → SKILL → 下一轮任务",
  whatEyebrow: "Life-driven self-evolution",
  whatTitle: "不是固定工作流，而是一套会改写自己的科研系统。",
  whatBody: "大模型只是可替换的推理组件。Argus 的 Life 在长期运行中持续吸收任务、环境与反馈，更新 Harness、Skills、Memory、工具和评测。在线进化不依赖参数训练，但由此积累的高密度过程数据可以用于训练模型。",
  pillars: [["Life：边工作边学习", "系统不只 7×24 执行任务，也持续读取结果、归因失败、更新记忆，并决定下一步应该学会什么。"], ["轻易扩展 OOD", "遇到分布外任务时，Argus 组合已有能力、生成新 Skill、接入新工具并创建新评测。"], ["上限与宽度保持开放", "Harness、Skills、Memory、工具与评测持续扩展；底层模型可以按任务选择和替换，在线演进无需训练自有模型。"]],
  loopTitle: "一次工作，怎样进入 Life 并变成下一次能力",
  loopNote: "每一轮都抬高能力上限、拓宽任务面，并加深长期记忆。",
  loopReturn: "Life 持续运行：工作、学习、再工作",
  loopSteps: [["01", "未知目标", "目标可以分布外，答案甚至可以尚不存在。"], ["02", "计划与执行", "组合模型、工具、记忆与已有 Skills。"], ["03", "证据与失败", "记录实验、反例、卡点和每次决策依据。"], ["04", "能力蒸馏", "生成可复用 Skill、Verifier、记忆与新任务。"], ["05", "Life 更新", "将证据写入长期记忆，更新路由、工作流、工具配置与评测。"], ["06", "扩展新边界", "下一类 OOD 任务不再从零开始。"]],
  dataEyebrow: "The missing data market",
  dataTitle: "论文公开了答案，却几乎从不公开答案是怎样被找到的。",
  dataBody: "一篇论文、一个数学猜想的背后，从 idea 如何产生，到遇到什么困难、为什么原路线失败、如何判断该换路，再到最终证据链——这些极其精细的过程通常是研究者的看家本领，也是今天公开科研记录中的巨大空白。Argus 原生记录这条过程。",
  trajectoryTitle: "一个科研成果背后的完整“研究电影”",
  trajectoryCaption: "PDF 只保留最后一帧；Argus 保留从想法到结果的整段轨迹。",
  trajectory: [["01", "Idea 起源", "为什么是这个问题、为什么是现在、最初判断来自哪里。"], ["02", "假设选择", "考虑过哪些路线，放弃了什么，关键假设和风险是什么。"], ["03", "失败分支", "哪次实验或证明尝试失败，出现了什么反常证据。"], ["04", "瓶颈诊断", "系统如何定位卡点，区分实现问题、数据问题与方法问题。"], ["05", "策略改道", "为什么更换模型、工具、Skill 或研究方向，依据是什么。"], ["06", "证据收敛", "有效结果如何复现、审计并最终形成论文、证明或工程成果。"]],
  processSignals: ["Idea provenance", "失败分支", "瓶颈诊断", "工具选择", "证据血缘", "改道理由"],
  businessTitle: "这不是日志，而是一种新的科研数据产品。",
  businessAssetEyebrow: "过程数据 → 复利资产",
  businessBody: "它比论文正文更细，比普通 CoT 更真实：带环境、工具、失败、反馈、版本和证据血缘，可服务科研 Agent 评测、Skill 构建、流程优化与研究复现，也可以作为高价值轨迹数据用于模型训练。",
  businessModels: [["DATA LICENSING", "过程数据授权", "按学科、任务和难度提供高密度研究轨迹，用于模型训练、Agent 评测、策略设计与研究复现。"], ["CAPABILITY ASSETS", "能力产品", "从轨迹中抽取 Skills、Verifier、Benchmark、工具适配器与领域工作流模块，形成可复用能力包。"], ["PRIVATE FLYWHEEL", "企业私域飞轮", "在企业或实验室环境内持续生成专属过程数据，让 Harness、Skills 与知识库越用越懂该领域。"]],
  businessFoot: "成果产生一次价值；过程数据、Skill 与评测资产可以持续复用、授权并产生复利。",
  governance: "商业化前提：完整 provenance、版权边界、脱敏、访问控制与客户数据隔离。",
  unknownTitle: "因为能够自进化，Argus 可以轻易扩展到新领域，并在其中越做越深。",
  oodEyebrow: "OOD 前沿扩展",
  unknownBody: "量化因子、文学、法律、数学证明、工程实践与科学研究的方法各不相同，但 Argus 不依赖一套锁死的工作流。它会为新领域接入数据、工具与验证环境，再把真实研究轨迹沉淀为领域专属的 Skills、Verifier 和长期记忆。",
  depthEyebrow: "Depth through evolution",
  depthTitle: "任何领域一旦进入专家级研究，就不可能只依赖模型训练时学到的知识。",
  depthBody: "预训练知识只能提供通用先验。严肃研究还需要最新资料、私有数据、领域规范、真实工具反馈、失败路径与可复验证据。自进化让这些部署后的经验不再丢失，而是不断转化为下一轮可以直接调用的能力。",
  depthSignals: [["预训练先验", "模型已有知识只是起点"], ["外部实践", "读取领域数据并使用真实工具"], ["验证反馈", "通过回测、判例、证明与实验判断真伪"], ["能力沉淀", "形成 Memory、Skill、Verifier 与新数据"]],
  domains: [["QUANT", "量化因子研究", "读取市场、基本面与另类数据，提出因子、回测归因、排除泄漏，并随市场 regime 持续更新。"], ["LITERATURE", "文学研究与创作", "阅读语料、研究风格与叙事，在创作、批评和重写中沉淀可复用的审美判断。"], ["LEGAL", "法律研究", "持续检索法条、判例和司法辖区差异，构建论证并核验引用、时效与适用边界。"], ["PROOF", "数学证明", "围绕猜想搜索结构、证明与反例，调用形式化工具，并完整保留每次失败和转向。"], ["ENGINEERING", "工程实践", "面对新硬件、软件栈与约束，通过 profiling 和真实实验持续定位瓶颈、优化实现。"], ["SCIENCE", "科学研究", "从开放问题出发阅读前沿工作、提出假设、设计实验或仿真，让证据决定下一步。"]],
  ctaTitle: "交付一个结果，也沉淀一个领域的能力与数据。",
  ctaBody: "从单个难题开始，Argus 交付可审计成果；从持续任务开始，形成领域 Skills、Verifier、工具链与高价值过程数据资产。",
  cta: "打开成绩墙 →",
  start: "开始使用 →",
} : {
  title: "Argus — A Self-Evolving Research Agent",
  description: "Argus turns every research run into data, skills, and evaluation signals, expanding into new OOD tasks while capturing the high-value process behind scientific results.",
  heroEyebrow: "Self-evolving research runtime",
  heroLead: "Give it a research objective.",
  heroEm: "It learns while it works.",
  lede: "Argus Life runs 24/7: reading, building, experimenting, and checking evidence—while learning from every success, failure, and pivot. Experience becomes memory, skills, evaluations, and process data, so the system keeps evolving into OOD work it has never seen before.",
  results: "See what it has accomplished →",
  evolutionLink: "See the evolution loop ↓",
  conceptLabel: "Core Argus capabilities",
  heroConcepts: [["Life learning", "Works 24/7 and learns from the work"], ["OOD expansion", "Novel tasks trigger new skills and tools"], ["Unfixed ceiling", "Expand across fields and deeper within them"]],
  metricLabel: "Selected results",
  metrics: [["#6", "NVIDIA global ranking"], ["2× #1", "B200 kernels"], ["H100 + B200", "Beyond human SOTA"], ["79.77s", "8×H100 speedrun"], ["41", "Research PDFs"]],
  signal: "LIFE → MISSION → EVIDENCE → MEMORY → SKILL → NEXT MISSION",
  whatEyebrow: "Life-driven self-evolution",
  whatTitle: "Not a fixed workflow. A research system that rewrites itself.",
  whatBody: "Models are swappable reasoning components. Argus Life continuously absorbs missions, environment changes, and feedback, updating the harness, skills, memory, tools, and evaluations. Online evolution does not depend on parameter training, but the dense process data it creates can be used to train models.",
  pillars: [["Life: learning while working", "The system does more than execute 24/7. It reads outcomes, attributes failures, updates memory, and decides what it should learn next."], ["Fast OOD expansion", "When a task falls outside the distribution, Argus composes existing capabilities, creates a new skill, connects a new tool, and builds a new evaluation."], ["An open ceiling and task surface", "The harness, skills, memory, tools, and evaluations keep expanding while underlying models remain selectable and swappable; online evolution does not require proprietary model training."]],
  loopTitle: "How one run enters Life and becomes the next capability",
  loopNote: "Every cycle raises the ceiling, widens the task surface, and deepens durable memory.",
  loopReturn: "Life keeps running: work, learn, and work again",
  loopSteps: [["01", "Unknown objective", "The task may be OOD and the answer may not exist yet."], ["02", "Plan and execute", "Compose models, tools, memory, and existing skills."], ["03", "Evidence and failure", "Record experiments, counterexamples, bottlenecks, and decisions."], ["04", "Distill capability", "Create reusable skills, verifiers, memory, and new tasks."], ["05", "Life update", "Write evidence into durable memory and update routing, workflows, tools, and evaluations."], ["06", "Expand the frontier", "The next class of OOD work no longer starts from zero."]],
  dataEyebrow: "The missing data market",
  dataTitle: "Papers publish the answer. They rarely publish how the answer was found.",
  dataBody: "Behind a paper or mathematical conjecture lies a path from the birth of an idea to dead ends, bottleneck diagnosis, strategic pivots, and the final chain of evidence. These fine-grained decisions are often a researcher's most guarded craft—and a vast blank space in today's public research record. Argus records that process natively.",
  trajectoryTitle: "The full research film behind one artifact",
  trajectoryCaption: "The PDF keeps the final frame. Argus keeps the path from idea to result.",
  trajectory: [["01", "Idea provenance", "Why this question, why now, and where the first judgment came from."], ["02", "Hypothesis choice", "Which routes were considered, what was rejected, and which assumptions carried risk."], ["03", "Failed branch", "Which experiment or proof attempt failed and what anomalous evidence appeared."], ["04", "Bottleneck diagnosis", "How the system separated implementation, data, and method failures."], ["05", "Strategic pivot", "Why it changed models, tools, skills, or direction—and on what evidence."], ["06", "Evidence convergence", "How the result became reproducible, auditable, and ready as a paper, proof, or system artifact."]],
  processSignals: ["Idea provenance", "Rejected branches", "Failure diagnosis", "Tool choice", "Evidence lineage", "Pivot rationale"],
  businessTitle: "This is not exhaust. It is a new research data product.",
  businessAssetEyebrow: "Process data → compounding asset",
  businessBody: "It is finer than the paper and more grounded than generic chain-of-thought: tied to environments, tools, failures, feedback, versions, and evidence lineage—useful for research-agent evaluation, skill construction, workflow optimization, reproducibility, and model training.",
  businessModels: [["DATA LICENSING", "Research trajectory data", "License dense, provenance-rich research trajectories by field, task, and difficulty for model training, agent evaluation, strategy design, and reproducibility."], ["CAPABILITY ASSETS", "Capability products", "Extract skills, verifiers, benchmarks, tool adapters, and domain workflow modules from successful trajectories."], ["PRIVATE FLYWHEEL", "Private domain flywheels", "Generate proprietary process data inside an enterprise or laboratory so its harness, skills, and knowledge base become more domain-native with every use."]],
  businessFoot: "A result creates value once. Process data, skills, and evaluations can be reused, licensed, and compounded.",
  governance: "Commercialization requires provenance, rights boundaries, redaction, access control, and strict customer-data isolation.",
  unknownTitle: "Because it self-evolves, Argus can enter new domains quickly—and keep getting deeper inside them.",
  oodEyebrow: "OOD frontier expansion",
  unknownBody: "Quant factors, literature, law, mathematical proof, engineering practice, and scientific research use very different methods. Argus is not bound to one frozen workflow: it connects the data, tools, and verification environment for a new field, then distills real research trajectories into domain-specific skills, verifiers, and durable memory.",
  depthEyebrow: "Depth through evolution",
  depthTitle: "No domain can reach expert-grade research by relying on pretrained knowledge alone.",
  depthBody: "Pretraining provides a general prior. Serious research also requires current literature, private data, domain rules, real tool feedback, failed paths, and reproducible evidence. Self-evolution keeps this post-deployment experience from disappearing and turns it into capability the next run can use directly.",
  depthSignals: [["Pretrained prior", "A model's existing knowledge is only the starting point"], ["External practice", "Read domain data and operate real tools"], ["Verified feedback", "Use backtests, cases, proofs, and experiments to decide what holds"], ["Capability distillation", "Create memory, skills, verifiers, and new data"]],
  domains: [["QUANT", "Quant factor research", "Read market, fundamental, and alternative data; propose factors, backtest and attribute them, eliminate leakage, and adapt across regimes."], ["LITERATURE", "Literary research and creation", "Study corpora, style, and narrative, then compound aesthetic judgment through creation, critique, and revision."], ["LEGAL", "Legal research", "Continuously retrieve statutes, cases, and jurisdictional differences while checking citations, currency, and applicability."], ["PROOF", "Mathematical proof", "Search for structures, proofs, and counterexamples around a conjecture, use formal tools, and preserve every failure and pivot."], ["ENGINEERING", "Engineering practice", "Across unfamiliar hardware, software stacks, and constraints, use profiling and real experiments to diagnose and optimize systems."], ["SCIENCE", "Scientific research", "Read frontier work, form hypotheses, design experiments or simulations, and let the evidence choose the next move."]],
  ctaTitle: "Deliver one result—and accumulate a domain's capability and data.",
  ctaBody: "Start with one hard problem for an auditable result. Continue with a stream of work to build domain skills, verifiers, toolchains, and high-value process-data assets.",
  cta: "Open the results wall →",
  start: "Get started →",
};
---

<SiteLayout
  title={copy.title}
  description={copy.description}
>
  <BrandUniverse locale={locale} />

  <section id="intro" class="page-hero product-intro">
    <div class="shell hero-system-grid">
      <div class="hero-system-copy">
        <p class="eyebrow">{copy.heroEyebrow}</p>
        <h1>{copy.heroLead}<br /><em>{copy.heroEm}</em></h1>
        <p class="lede">{copy.lede}</p>
        <div class="hero-actions">
          <a class="button primary" href={href("/results.html")}>{copy.results}</a>
          <a class="button" href="#evolution">{copy.evolutionLink}</a>
        </div>
        <div class="hero-thesis" aria-label={copy.conceptLabel}>
          {copy.heroConcepts.map(([title, body]) => <div><strong>{title}</strong><span>{body}</span></div>)}
        </div>
      </div>
      <ResearchField locale={locale} />
    </div>
  </section>

  <section class="metric-strip" aria-label={copy.metricLabel}>
    <div class="metric-grid">
      {copy.metrics.map(([value, label]) => <div class="metric"><strong>{value}</strong><span>{label}</span></div>)}
    </div>
  </section>

  <div class="signal-rail" aria-hidden="true">
    <div>
      <span>{copy.signal}</span>
      <span>{copy.signal}</span>
      <span>{copy.signal}</span>
    </div>
  </div>

  <section id="evolution" class="section">
    <div class="shell">
      <div class="section-head">
        <p class="eyebrow">{copy.whatEyebrow}</p>
        <h2>{copy.whatTitle}</h2>
        <p>{copy.whatBody}</p>
      </div>
      <div class="card-grid">
        {copy.pillars.map(([title, body], index) => <article class="card"><span class="number">{String(index + 1).padStart(2, "0")}</span><h3>{title}</h3><p>{body}</p></article>)}
      </div>
      <div class="evolution-loop">
        <div class="evolution-loop__intro">
          <strong>{copy.loopTitle}</strong>
          <span>{copy.loopNote}</span>
        </div>
        <div class="evolution-loop__viewport">
          <div class="evolution-loop__track">
            {copy.loopSteps.map(([number, title, body]) => <div class="evolution-step"><span>{number}</span><strong>{title}</strong><p>{body}</p></div>)}
          </div>
        </div>
        <div class="evolution-loop__return"><span aria-hidden="true">↺</span>{copy.loopReturn}</div>
      </div>
    </div>
  </section>

  <section id="process-data" class="section surface data-economy">
    <div class="shell">
      <div class="section-head wide">
        <p class="eyebrow">{copy.dataEyebrow}</p>
        <h2>{copy.dataTitle}</h2>
        <p>{copy.dataBody}</p>
      </div>
      <div class="process-data-grid">
        <article class="trajectory-ledger">
          <div class="trajectory-ledger__head">
            <h3>{copy.trajectoryTitle}</h3>
            <p>{copy.trajectoryCaption}</p>
          </div>
          <div class="trajectory-list">
            {copy.trajectory.map(([number, title, body]) => (
              <div class="trajectory-entry">
                <span>{number}</span>
                <div><strong>{title}</strong><p>{body}</p></div>
              </div>
            ))}
          </div>
          <div class="trajectory-signals">
            {copy.processSignals.map((signal) => <span>{signal}</span>)}
          </div>
        </article>

        <div class="business-case">
          <div class="business-thesis">
            <p class="eyebrow">{copy.businessAssetEyebrow}</p>
            <h3>{copy.businessTitle}</h3>
            <p>{copy.businessBody}</p>
          </div>
          <div class="business-grid">
            {copy.businessModels.map(([badge, title, body]) => (
              <article class="card business-card">
                <span class="business-badge">{badge}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))}
          </div>
          <p class="business-foot">{copy.businessFoot}</p>
          <p class="data-governance">{copy.governance}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <p class="eyebrow">{copy.oodEyebrow}</p>
        <h2>{copy.unknownTitle}</h2>
        <p>{copy.unknownBody}</p>
      </div>
      <article class="card depth-principle">
        <div class="depth-principle__copy">
          <p class="eyebrow">{copy.depthEyebrow}</p>
          <h3>{copy.depthTitle}</h3>
          <p>{copy.depthBody}</p>
        </div>
        <div class="depth-principle__flow">
          {copy.depthSignals.map(([title, body], index) => (
            <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{title}</strong><small>{body}</small></div>
          ))}
        </div>
      </article>
      <div class="card-grid domain-grid">
        {copy.domains.map(([badge, title, body]) => <article class="card domain-card"><span class="domain-badge">{badge}</span><h3>{title}</h3><p>{body}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="cta-band">
        <h2>{copy.ctaTitle}</h2>
        <p>{copy.ctaBody}</p>
        <div class="hero-actions">
          <a class="button" href={href("/results.html")}>{copy.cta}</a>
          <a class="button" href={href("/start.html")}>{copy.start}</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
