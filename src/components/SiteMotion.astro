<script>
  const root = document.documentElement;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const revealSelector = [
    ".section-head",
    ".card",
    ".metric",
    ".score-row",
    ".role",
    ".pipeline > div",
    ".figure",
    ".cta-band",
    ".demo-intro",
    ".demo-frame",
    ".demo-caption",
    ".demo-points > span",
    ".runtime-flow__track > div",
    ".evolution-step",
    ".trajectory-entry",
    ".business-thesis",
    ".business-foot",
    ".data-governance",
  ].join(",");
  const resetMotionStyles = () => {
    document.querySelectorAll<HTMLElement>(
      `${revealSelector}, .site-header, .page-hero .eyebrow, .page-hero h1, .page-hero .hero-title, .page-hero .lede, .page-hero .hero-actions, .page-hero .hero-thesis > div, .page-hero .demo-source, [data-research-field], [data-brand-word], [data-brand-core], .brand-universe__core, .brand-universe__enter`,
    ).forEach((element) => {
      element.style.removeProperty("opacity");
      element.style.removeProperty("visibility");
      element.style.removeProperty("transform");
    });
  };

  if (reduceMotion) {
    root.classList.remove("motion-prep");
  } else {
    void import("gsap").then(({ gsap }) => {
      const heroTargets = gsap.utils.toArray<HTMLElement>(
        ".page-hero .eyebrow, .page-hero h1, .page-hero .hero-title, .page-hero .lede, .page-hero .hero-actions, .page-hero .hero-thesis > div, .page-hero .demo-source, [data-research-field]",
      );
      const revealTargets = gsap.utils.toArray<HTMLElement>(revealSelector);
      const brandUniverse = document.querySelector<HTMLElement>("[data-brand-universe]");
      const brandWordLayer = document.querySelector<HTMLElement>("[data-brand-word-layer]");
      const brandWords = gsap.utils.toArray<HTMLElement>("[data-brand-word]");
      const activeBrandWords = brandWords.filter((word) => getComputedStyle(word).display !== "none");
      const brandWordOpacities = activeBrandWords.map((word) => Number(getComputedStyle(word).opacity));
      const brandCore = document.querySelector<HTMLElement>("[data-brand-core]");
      const brandCoreScroll = document.querySelector<HTMLElement>("[data-brand-core-scroll]");
      const brandHalo = document.querySelector<HTMLElement>(".brand-universe__halo");
      const brandEnter = document.querySelector<HTMLElement>(".brand-universe__enter");
      const brandAnimations: gsap.core.Animation[] = [];
      let brandVisibilityObserver: IntersectionObserver | null = null;
      const canObserve = "IntersectionObserver" in window;
      const pointerCleanups: Array<() => void> = [];
      const finePointer = window.matchMedia("(pointer: fine) and (hover: hover)").matches;
      const coarsePointer = window.matchMedia("(pointer: coarse), (hover: none)").matches;
      const pointerSurfaces = new WeakSet<Element>();

      if (brandUniverse && brandCore) {
        const forms = [
          ["ARGUS", 0], ["Argus", 3], ["argus", 8], ["ARGUS", 2], ["Argus", 5],
          ["argus", 7], ["ARGUS", 1], ["Argus", 9], ["argus", 4], ["ARGUS", 6],
        ] as const;
        let formIndex = 0;
        activeBrandWords.forEach((word, index) => {
          brandAnimations.push(gsap.to(word, {
            x: `random(${-20 - index % 3 * 4}, ${20 + index % 4 * 3})`,
            y: `random(${-16 - index % 4 * 3}, ${16 + index % 3 * 4})`,
            rotation: `random(${-8 - index % 3}, ${8 + index % 4})`,
            duration: `random(${10 + index % 5}, ${20 + index % 7})`,
            ease: "sine.inOut",
            repeat: -1,
            yoyo: true,
            repeatRefresh: true,
          }));
        });
        brandAnimations.push(gsap.timeline({ repeat: -1, repeatDelay: 1.45, delay: 1.5 })
          .to(brandCore, { autoAlpha: 0, scale: 0.965, duration: 0.22, ease: "power2.in" })
          .call(() => {
            formIndex = (formIndex + 1) % forms.length;
            const [text, font] = forms[formIndex];
            brandCore.textContent = text;
            brandCore.className = `font-${font}`;
            brandCore.dataset.palette = String(formIndex % 4);
          })
          .to(brandCore, {
            autoAlpha: 1,
            scale: 1,
            duration: 0.42,
            ease: "back.out(1.8)",
            transformOrigin: "50% 50%",
          }));
        if (brandEnter) {
            brandAnimations.push(gsap.to(brandEnter.querySelector("i"), {
            y: 6,
            duration: 1.25,
            ease: "sine.inOut",
            repeat: -1,
            yoyo: true,
          }));
        }
        if ("IntersectionObserver" in window) {
          brandVisibilityObserver = new IntersectionObserver(([entry]) => {
            brandAnimations.forEach((animation) => animation.paused(!entry?.isIntersecting));
          }, { threshold: 0.02 });
          brandVisibilityObserver.observe(brandUniverse);
        }
      }

      const attachPointerSurface = (surface: HTMLElement) => {
        if (!finePointer || pointerSurfaces.has(surface)) return;
        pointerSurfaces.add(surface);
        const move = (event: PointerEvent) => {
          const rect = surface.getBoundingClientRect();
          surface.style.setProperty("--pointer-x", `${event.clientX - rect.left}px`);
          surface.style.setProperty("--pointer-y", `${event.clientY - rect.top}px`);
          if (surface.matches(".card, .paper-card, .role, .launch-command")) {
            rotateYTo(((event.clientX - rect.left) / rect.width - 0.5) * 4.5);
            rotateXTo(-((event.clientY - rect.top) / rect.height - 0.5) * 3.5);
          }
        };
        const rotateXTo = gsap.quickTo(surface, "rotationX", {
          duration: 0.38,
          ease: "power3.out",
        });
        const rotateYTo = gsap.quickTo(surface, "rotationY", {
          duration: 0.38,
          ease: "power3.out",
        });
        const enter = () => gsap.to(surface, {
          "--spotlight-opacity": 1,
          duration: 0.2,
          ease: "power1.out",
          overwrite: "auto",
        });
        const leave = () => {
          gsap.to(surface, {
            "--spotlight-opacity": 0,
            rotationX: 0,
            rotationY: 0,
            duration: 0.42,
            ease: "power2.out",
            overwrite: "auto",
            clearProps: "transform",
          });
        };
        surface.addEventListener("pointermove", move);
        surface.addEventListener("pointerenter", enter);
        surface.addEventListener("pointerleave", leave);
        pointerCleanups.push(() => {
          surface.removeEventListener("pointermove", move);
          surface.removeEventListener("pointerenter", enter);
          surface.removeEventListener("pointerleave", leave);
        });
      };

      if (finePointer) {
        const ambientMove = (event: PointerEvent) => {
          document.body.style.setProperty("--ambient-x", `${event.clientX}px`);
          document.body.style.setProperty("--ambient-y", `${event.clientY}px`);
        };
        window.addEventListener("pointermove", ambientMove, { passive: true });
        pointerCleanups.push(() => {
          window.removeEventListener("pointermove", ambientMove);
        });
        document.querySelectorAll<HTMLElement>(
          ".page-hero, .card, .score-row, .role, .launch-command, .paper-card",
        ).forEach(attachPointerSurface);
        if (brandUniverse && brandWordLayer && brandCore) {
          const layerX = gsap.quickTo(brandWordLayer, "x", { duration: 0.9, ease: "power3.out" });
          const layerY = gsap.quickTo(brandWordLayer, "y", { duration: 0.9, ease: "power3.out" });
          const coreX = gsap.quickTo(brandCore, "x", { duration: 0.7, ease: "power3.out" });
          const coreY = gsap.quickTo(brandCore, "y", { duration: 0.7, ease: "power3.out" });
          const brandMove = (event: PointerEvent) => {
            const rect = brandUniverse.getBoundingClientRect();
            const x = (event.clientX - (rect.left + rect.width / 2)) / rect.width;
            const y = (event.clientY - (rect.top + rect.height / 2)) / rect.height;
            layerX(x * -24);
            layerY(y * -18);
            coreX(x * 8);
            coreY(y * 6);
          };
          brandUniverse.addEventListener("pointermove", brandMove, { passive: true });
          pointerCleanups.push(() => brandUniverse.removeEventListener("pointermove", brandMove));
        }
        document.querySelectorAll<HTMLElement>(".button, .site-start").forEach((element) => {
          const xTo = gsap.quickTo(element, "x", { duration: 0.3, ease: "power3.out" });
          const yTo = gsap.quickTo(element, "y", { duration: 0.3, ease: "power3.out" });
          const move = (event: PointerEvent) => {
            const rect = element.getBoundingClientRect();
            xTo((event.clientX - (rect.left + rect.width / 2)) * 0.12);
            yTo((event.clientY - (rect.top + rect.height / 2)) * 0.16);
          };
          const leave = () => gsap.to(element, {
            x: 0,
            y: 0,
            duration: 0.42,
            ease: "elastic.out(1, 0.45)",
            clearProps: "transform",
          });
          element.addEventListener("pointermove", move);
          element.addEventListener("pointerleave", leave);
          pointerCleanups.push(() => {
            element.removeEventListener("pointermove", move);
            element.removeEventListener("pointerleave", leave);
          });
        });
      }
      if (coarsePointer) {
        const touchPress = (event: PointerEvent) => {
          if (event.pointerType === "mouse") return;
          const target = (event.target as Element | null)?.closest<HTMLElement>(
            ".card, .paper-card, .role, .button, .site-start, [data-research-field-plane]",
          );
          if (!target) return;
          gsap.fromTo(target, { scale: 0.985 }, {
            scale: 1,
            duration: 0.36,
            ease: "back.out(2.2)",
            clearProps: "scale",
            overwrite: "auto",
          });
          if (target.matches("[data-research-field-plane]")) {
            gsap.fromTo("[data-research-field-node]", { scale: 0.9 }, {
              scale: 1,
              duration: 0.4,
              stagger: 0.055,
              ease: "back.out(2)",
              clearProps: "scale",
            });
          }
        };
        document.addEventListener("pointerdown", touchPress, { passive: true });
        pointerCleanups.push(() => document.removeEventListener("pointerdown", touchPress));
      }

      const progress = document.querySelector<HTMLElement>("[data-scroll-progress]");
      if (progress) {
        const progressTo = gsap.quickTo(progress, "scaleX", {
          duration: 0.22,
          ease: "power1.out",
        });
        const updateProgress = () => {
          const range = document.documentElement.scrollHeight - window.innerHeight;
          progressTo(range > 0 ? window.scrollY / range : 0);
        };
        window.addEventListener("scroll", updateProgress, { passive: true });
        window.addEventListener("resize", updateProgress);
        updateProgress();
        pointerCleanups.push(() => {
          window.removeEventListener("scroll", updateProgress);
          window.removeEventListener("resize", updateProgress);
        });
      }

      if (brandUniverse && brandWordLayer && brandCoreScroll && brandHalo) {
        const compactHero = window.matchMedia("(max-width: 760px)").matches;
        const scaleTo = (target: HTMLElement, duration: number) => {
          const scaleXTo = gsap.quickTo(target, "scaleX", { duration, ease: "power2.out" });
          const scaleYTo = gsap.quickTo(target, "scaleY", { duration, ease: "power2.out" });
          return (value: number) => {
            scaleXTo(value);
            scaleYTo(value);
          };
        };
        const coreScaleTo = scaleTo(brandCoreScroll, 0.22);
        const coreYTo = gsap.quickTo(brandCoreScroll, "y", { duration: 0.22, ease: "power2.out" });
        const coreOpacityTo = gsap.quickTo(brandCoreScroll, "opacity", { duration: 0.18, ease: "power1.out" });
        const wordsScaleTo = scaleTo(brandWordLayer, 0.25);
        const wordsOpacityTo = gsap.quickTo(brandWordLayer, "opacity", { duration: 0.2, ease: "power1.out" });
        const haloScaleTo = scaleTo(brandHalo, 0.28);
        const enterOpacityTo = brandEnter
          ? gsap.quickTo(brandEnter, "opacity", { duration: 0.16, ease: "power1.out" })
          : null;
        const updateBrandScroll = () => {
          const range = Math.max(1, brandUniverse.offsetHeight * 0.8);
          const amount = Math.min(1, Math.max(0, (window.scrollY - brandUniverse.offsetTop) / range));
          coreScaleTo(1 - amount * (compactHero ? 0.18 : 0.28));
          coreYTo(amount * (compactHero ? -12 : -36));
          coreOpacityTo(1 - amount * 0.12);
          wordsScaleTo(1 - amount * (compactHero ? 0.1 : 0.18));
          wordsOpacityTo(1 - amount * 0.32);
          haloScaleTo(1 - amount * (compactHero ? 0.14 : 0.24));
          enterOpacityTo?.(Math.max(0, 1 - amount * 2.4));
        };
        window.addEventListener("scroll", updateBrandScroll, { passive: true });
        window.addEventListener("resize", updateBrandScroll);
        updateBrandScroll();
        pointerCleanups.push(() => {
          window.removeEventListener("scroll", updateBrandScroll);
          window.removeEventListener("resize", updateBrandScroll);
        });
      }

      const researchField = document.querySelector<HTMLElement>("[data-research-field]");
      const researchPlane = document.querySelector<HTMLElement>("[data-research-field-plane]");
      if (researchField) {
        gsap.to(".research-field__link", {
          strokeDashoffset: -72,
          duration: 4.8,
          ease: "none",
          repeat: -1,
        });
        gsap.to("[data-research-field-scan]", {
          rotation: 360,
          duration: 12,
          ease: "none",
          repeat: -1,
          transformOrigin: "50% 50%",
        });
        gsap.to("[data-research-field-core]", {
          scale: 1.035,
          duration: 1.7,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          transformOrigin: "50% 50%",
        });
        gsap.to("[data-research-field-node]", {
          y: (index) => index % 2 === 0 ? -5 : 5,
          duration: 2.2,
          stagger: 0.18,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
        });
        gsap.to("[data-research-field-particle]", {
          x: "random(-10, 10)",
          y: "random(-9, 9)",
          scale: "random(0.7, 1.45)",
          opacity: "random(0.32, 0.9)",
          duration: "random(1.8, 3.6)",
          stagger: 0.11,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          repeatRefresh: true,
        });
      }
      if (finePointer && researchPlane) {
        const rotateXTo = gsap.quickTo(researchPlane, "rotationX", { duration: 0.6, ease: "power3.out" });
        const rotateYTo = gsap.quickTo(researchPlane, "rotationY", { duration: 0.6, ease: "power3.out" });
        const fieldMove = (event: PointerEvent) => {
          const rect = researchPlane.getBoundingClientRect();
          rotateYTo(((event.clientX - rect.left) / rect.width - 0.5) * 5);
          rotateXTo(-((event.clientY - rect.top) / rect.height - 0.5) * 4);
        };
        const fieldLeave = () => gsap.to(researchPlane, {
          rotationX: 0,
          rotationY: 0,
          duration: 0.7,
          ease: "power3.out",
          clearProps: "transform",
        });
        researchPlane.addEventListener("pointermove", fieldMove);
        researchPlane.addEventListener("pointerleave", fieldLeave);
        pointerCleanups.push(() => {
          researchPlane.removeEventListener("pointermove", fieldMove);
          researchPlane.removeEventListener("pointerleave", fieldLeave);
        });
      }

      if (brandUniverse) {
        gsap.set(heroTargets, { autoAlpha: 0, y: 24 });
        gsap.set(activeBrandWords, { autoAlpha: 0 });
        gsap.set(".brand-universe__core, .brand-universe__enter", { autoAlpha: 0 });
      } else {
        gsap.set(heroTargets, { y: 12 });
      }
      if (canObserve) gsap.set(revealTargets, { autoAlpha: 0, y: 20 });
      root.classList.remove("motion-prep");

      gsap.timeline({ defaults: { ease: "power3.out" } })
        .fromTo(".site-header", { autoAlpha: 0, y: -12 }, { autoAlpha: 1, y: 0, duration: 0.42 })
        .to(activeBrandWords, {
          autoAlpha: (index) => brandWordOpacities[index] ?? 0.2,
          duration: 0.9,
          stagger: { amount: 0.7, from: "random" },
          clearProps: "opacity,visibility",
        }, 0)
        .fromTo(
          ".brand-universe__core",
          { autoAlpha: 0, scale: 0.9 },
          { autoAlpha: 1, scale: 1, duration: 1, ease: "power3.out" },
          0.08,
        )
        .to(".brand-universe__enter", { autoAlpha: 1, duration: 0.5 }, 0.7)
        .to(heroTargets, {
          autoAlpha: 1,
          y: 0,
          duration: 0.68,
          stagger: 0.09,
          clearProps: "transform,opacity,visibility",
        }, 0.06);

      const observer = canObserve ? new IntersectionObserver((entries) => {
        for (const entry of entries) {
          const targets = [...entry.target.querySelectorAll<HTMLElement>(revealSelector)];
          if (!targets.length) continue;
          if (entry.isIntersecting) {
            gsap.to(targets, {
              autoAlpha: 1,
              y: 0,
              duration: 0.62,
              stagger: { amount: Math.min(0.48, targets.length * 0.07) },
              ease: "power2.out",
              overwrite: "auto",
              clearProps: "transform,opacity,visibility",
            });
          } else {
            gsap.to(targets, {
              autoAlpha: 0,
              y: entry.boundingClientRect.top < 0 ? -14 : 14,
              duration: 0.28,
              ease: "power1.out",
              overwrite: "auto",
            });
          }
        }
      }, { rootMargin: "-6% 0px -10% 0px", threshold: 0.08 }) : null;

      if (observer) {
        document.querySelectorAll<HTMLElement>(".metric-strip, .runtime-flow, .section")
          .forEach((section) => observer.observe(section));
      }

      const animatedCards = new WeakSet<Element>();
      const animatePaperCards = () => {
        const cards = [...document.querySelectorAll<HTMLElement>(".paper-card")]
          .filter((card) => !animatedCards.has(card));
        cards.forEach((card) => animatedCards.add(card));
        cards.forEach(attachPointerSurface);
        if (!cards.length) return;
        gsap.fromTo(cards, { autoAlpha: 0, y: 16 }, {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          stagger: { amount: Math.min(0.4, cards.length * 0.04) },
          ease: "power2.out",
          clearProps: "transform,opacity,visibility",
        });
      };
      const mutationObserver = "MutationObserver" in window
        ? new MutationObserver(animatePaperCards)
        : null;
      let paperCardMotionStarted = false;
      const startPaperCardMotion = () => {
        if (paperCardMotionStarted) return;
        paperCardMotionStarted = true;
        mutationObserver?.observe(document.body, { childList: true, subtree: true });
        animatePaperCards();
      };
      document.addEventListener("argus:paper-explorer-ready", startPaperCardMotion, { once: true });
      if (root.dataset.paperExplorerReady === "true") startPaperCardMotion();
      window.addEventListener("pagehide", (event) => {
        if (event.persisted) return;
        observer?.disconnect();
        mutationObserver?.disconnect();
        brandVisibilityObserver?.disconnect();
        document.removeEventListener("argus:paper-explorer-ready", startPaperCardMotion);
        pointerCleanups.forEach((cleanup) => cleanup());
      }, { once: true });
    }).catch(() => {
      root.classList.remove("motion-prep");
      resetMotionStyles();
    });
  }
</script>
