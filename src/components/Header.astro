---
import { localeFromPath, pathForLocale } from "../i18n";
import ArgusLogo from "./ArgusLogo.astro";

const path = Astro.url.pathname;
const locale = localeFromPath(path);
const copy = locale === "zh" ? {
  home: "Argus 首页",
  nav: "主导航",
  light: "切换到白天模式",
  dark: "切换到黑夜模式",
  links: ["首页", "成绩", "研究", "原理", "场景", "开始使用"],
} : {
  home: "Argus home",
  nav: "Main navigation",
  light: "Switch to light mode",
  dark: "Switch to dark mode",
  links: ["Home", "Results", "Research", "How it works", "Use cases", "Get started"],
};
const links = [
  { href: "/", label: copy.links[0] },
  { href: "/results.html", label: copy.links[1] },
  { href: "/research.html", label: copy.links[2] },
  { href: "/how.html", label: copy.links[3] },
  { href: "/use-cases.html", label: copy.links[4] },
  { href: "/start.html", label: copy.links[5] },
];
const localized = (href: string) => pathForLocale(href, locale);
const currentBase = pathForLocale(path, "en");
---

<header class="site-header">
  <div class="site-progress" data-scroll-progress aria-hidden="true"></div>
  <div class="site-header__inner">
    <a class="site-brand" href={localized("/")} aria-label={copy.home}>
      <ArgusLogo variant="horizontal" class="argus-logo--header" decorative />
    </a>
    <nav class="site-nav" aria-label={copy.nav}>
      {links.map((link) => (
        <a href={localized(link.href)} aria-current={currentBase === link.href ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </nav>
    <nav class="language-switcher" aria-label="Language">
      <a href={pathForLocale(path, "en")} hreflang="en" lang="en" aria-current={locale === "en" ? "page" : undefined}>EN</a>
      <span aria-hidden="true">/</span>
      <a href={pathForLocale(path, "zh")} hreflang="zh-Hans" lang="zh-CN" aria-current={locale === "zh" ? "page" : undefined}>中</a>
    </nav>
    <button
      class="theme-toggle"
      type="button"
      data-theme-toggle
      data-label-light={copy.light}
      data-label-dark={copy.dark}
      aria-label={copy.dark}
      title={copy.dark}
    >
      <svg class="theme-icon theme-icon--moon" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M16.2 12.8A7 7 0 0 1 7.2 3.8 7 7 0 1 0 16.2 12.8Z" />
      </svg>
      <svg class="theme-icon theme-icon--sun" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="10" cy="10" r="3.25" />
        <path d="M10 1.5v2M10 16.5v2M1.5 10h2M16.5 10h2M4 4l1.4 1.4M14.6 14.6 16 16M16 4l-1.4 1.4M5.4 14.6 4 16" />
      </svg>
    </button>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-theme-toggle]");
  if (toggle instanceof HTMLButtonElement && toggle.dataset.ready !== "true") {
    toggle.dataset.ready = "true";
    const media = window.matchMedia("(prefers-color-scheme: dark)");
    const savedTheme = () => {
      try {
        return localStorage.getItem("argus-site-theme");
      } catch {
        return null;
      }
    };
    const apply = (theme) => {
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme;
      document.querySelector('meta[name="theme-color"]')?.setAttribute(
        "content",
        theme === "dark" ? "#07101c" : "#ffffff",
      );
      const label = theme === "dark"
        ? toggle.dataset.labelLight
        : toggle.dataset.labelDark;
      if (label) {
        toggle.setAttribute("aria-label", label);
        toggle.title = label;
      }
    };
    apply(document.documentElement.dataset.theme === "dark" ? "dark" : "light");
    toggle.addEventListener("click", () => {
      const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      apply(next);
      try {
        localStorage.setItem("argus-site-theme", next);
      } catch {
        // Theme still applies for this page when persistence is unavailable.
      }
    });
    media.addEventListener("change", (event) => {
      if (!savedTheme()) {
        apply(event.matches ? "dark" : "light");
      }
    });
  }
</script>
