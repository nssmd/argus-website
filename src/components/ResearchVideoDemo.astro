---

<div class="run-demo" data-research-video-switcher>
  <div class="run-picker" id="run-picker" data-run-picker>
    <div class="run-picker__head">
      <h3>{copy.heading}</h3>
      <p>{copy.subheading}</p>
    </div>

    <div class="run-rail" role="tablist" aria-label={copy.heading}>
      {copy.runs.map((run, index) => (
        <button
          id={`run-card-${index}`}
          class="run-card"
          type="button"
          role="tab"
          aria-controls="research-video-panel"
          aria-selected={index === 0 ? "true" : "false"}
          tabindex={index === 0 ? 0 : -1}
          data-video-src={run.src}
          data-video-poster={run.poster}
          data-video-label={run.label}
        >
          <span class="run-card__poster" style={`background-image: url(${run.poster})`} aria-hidden="true"></span>
          <span class="run-card__scrim" aria-hidden="true"></span>
          <span class="run-card__category" data-run-category>{run.category}</span>
          <span class="run-card__now" data-now-playing>{copy.nowPlaying}</span>
          <span class="run-card__play" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" focusable="false"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
          </span>
          <span class="run-card__body">
            <strong class="run-card__title">{run.title}</strong>
            <span class="run-card__meta">
              <span class="run-card__duration" data-run-duration>{run.duration}</span>
              <span class="run-card__pacing">{run.pacing}</span>
            </span>
          </span>
        </button>
      ))}
    </div>
    <p class="run-rail__hint" aria-hidden="true">{copy.swipeHint}</p>
  </div>

  <div class="demo-frame terminal-demo run-player">
    <div class="demo-frame__bar">
      <span class="window-dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <strong>{copy.frameTitle}</strong>
      <span>{copy.frameBadge}</span>
    </div>
    <div
      id="research-video-panel"
      class="research-video-stage"
      role="tabpanel"
      aria-labelledby="run-card-0"
    >
      <video
        data-research-video
        controls
        loop
        muted
        playsinline
        preload="metadata"
        poster={copy.runs[0].poster}
        aria-label={copy.runs[0].label}
      >
        <source src={copy.runs[0].src} type="video/mp4" />
        <a data-video-download href={copy.runs[0].src}>{copy.download}</a>
      </video>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-research-video-switcher]").forEach((root) => {
    if (root.dataset.ready === "true") return;

    const video = root.querySelector<HTMLVideoElement>("[data-research-video]");
    const source = video?.querySelector<HTMLSourceElement>("source");
    const download = video?.querySelector<HTMLAnchorElement>("[data-video-download]");
    const panel = root.querySelector<HTMLElement>('[role="tabpanel"]');
    const player = root.querySelector<HTMLElement>(".run-player");
    const buttons = [...root.querySelectorAll<HTMLButtonElement>("[data-video-src]")];

    if (!(video && source && download && panel && buttons.length > 0)) return;

    root.dataset.ready = "true";
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const desktop = window.matchMedia("(min-width: 821px)");
    let visible = false;
    let activeSource = "";

    const playWhenAppropriate = () => {
      if (visible && !reducedMotion) void video.play().catch(() => undefined);
    };

    const load = (button: HTMLButtonElement, scrollIntoView = false) => {
      const nextSource = button.dataset.videoSrc ?? "";

      buttons.forEach((candidate) => {
        const selected = candidate === button;
        candidate.setAttribute("aria-selected", String(selected));
        candidate.tabIndex = selected ? 0 : -1;
      });
      panel.setAttribute("aria-labelledby", button.id);

      if (scrollIntoView && desktop.matches && player) {
        player.scrollIntoView({
          behavior: reducedMotion ? "auto" : "smooth",
          block: "nearest",
        });
      }

      if (nextSource === activeSource) {
        playWhenAppropriate();
        return;
      }

      activeSource = nextSource;
      video.pause();
      source.src = nextSource;
      video.poster = button.dataset.videoPoster ?? "";
      video.setAttribute("aria-label", button.dataset.videoLabel ?? "");
      download.href = nextSource;
      video.load();
      playWhenAppropriate();
    };

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => load(button, true));
      button.addEventListener("keydown", (event) => {
        let nextIndex: number | undefined;

        if (event.key === "ArrowRight" || event.key === "ArrowDown") {
          nextIndex = (index + 1) % buttons.length;
        } else if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
          nextIndex = (index - 1 + buttons.length) % buttons.length;
        } else if (event.key === "Home") {
          nextIndex = 0;
        } else if (event.key === "End") {
          nextIndex = buttons.length - 1;
        }

        if (nextIndex === undefined) return;
        event.preventDefault();
        const next = buttons[nextIndex];
        if (next) {
          next.focus();
          load(next, true);
        }
      });
    });

    load(buttons[0]);

    new IntersectionObserver(
      ([entry]) => {
        visible = Boolean(entry?.isIntersecting);
        if (visible) playWhenAppropriate();
        else video.pause();
      },
      { threshold: 0.2 },
    ).observe(root);
  });
</script>
