---
import SiteLayout from "../layouts/SiteLayout.astro";
import { localeFromPath, pathForLocale } from "../i18n";

const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => pathForLocale(path, locale);
const copy = locale === "zh" ? {
  title: "Use Cases · Argus",
  description: "Argus 适合需要创新、长程执行和可验证结果的高成本研究任务。",
  hero: "把最贵的研究循环搬上机器。",
  lede: "答案需要发明、过程要持续数天、结果又能被真实指标验证——这就是 Argus 的任务形状。",
  shapes: [["需要创新", "答案不在手册里，必须在真实反馈中搜索出来。"], ["需要长程", "一次做不完，要连续数小时到数天迭代。"], ["可以验证", "有清晰指标判断方案是否真的更好。"]],
  deploy: "同一种劳动，不同的行业。",
  domains: [["性能工程", "profile、改 kernel、测真实延迟，持续砍算力成本。"], ["安全研究", "围绕可验证 exploit 不断形成并测试新假设。"], ["硬科学", "分子、材料、芯片等高成本实验空间的长期搜索。"], ["量化研究", "因子提出、回测、诊断失效、再发明。"]],
  ctaTitle: "你的问题适合 Argus 吗？",
  ctaBody: "如果它需要昂贵的人持续试错，而且结果可以测，就值得交给 Argus。",
  cta: "查看安装与 Release →",
} : {
  title: "Use Cases · Argus",
  description: "Argus is built for expensive research work that demands invention, sustained execution, and verifiable outcomes.",
  hero: "Move the most expensive research loops onto the machine.",
  lede: "The answer has to be invented, the work may run for days, and the outcome must survive a real metric. That is the shape of an Argus task.",
  shapes: [["It requires invention", "The answer is not in a manual. It has to be discovered through real feedback."], ["It takes time", "One pass is not enough; progress requires hours or days of sustained iteration."], ["It can be verified", "A clear metric can tell you whether the proposed solution is genuinely better."]],
  deploy: "The same research labor, across different domains.",
  domains: [["Performance engineering", "Profile the system, rewrite kernels, measure real latency, and keep reducing compute cost."], ["Security research", "Form and test new hypotheses against exploits that can actually be reproduced."], ["Hard science", "Search costly experimental spaces in molecules, materials, chips, and adjacent fields."], ["Quantitative research", "Propose factors, backtest them, diagnose failure, and invent again."]],
  ctaTitle: "Is your problem a fit for Argus?",
  ctaBody: "If it burns through expert trial and error—and the result can be measured—it is worth handing to Argus.",
  cta: "Installation & release →",
};
---

<SiteLayout
  title={copy.title}
  description={copy.description}
>
  <section class="page-hero compact">
    <div class="shell">
      <p class="eyebrow">Use cases</p>
      <h1>{copy.hero}</h1>
      <p class="lede">{copy.lede}</p>
    </div>
  </section>

  <section class="section tight">
    <div class="shell">
      <div class="card-grid">
        {copy.shapes.map(([title, body], index) => <article class="card"><span class="number">{String(index + 1).padStart(2, "0")}</span><h3>{title}</h3><p>{body}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="shell">
      <div class="section-head">
        <p class="eyebrow">Where to deploy it</p>
        <h2>{copy.deploy}</h2>
      </div>
      <div class="card-grid four">
        {copy.domains.map(([title, body]) => <article class="card"><h3>{title}</h3><p>{body}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="cta-band">
        <h2>{copy.ctaTitle}</h2>
        <p>{copy.ctaBody}</p>
        <a class="button primary" href={href("/release.html")}>{copy.cta}</a>
      </div>
    </div>
  </section>
</SiteLayout>
